{
    "workbench.colorTheme": "GitHub Dark Dimmed",
    "workbench.iconTheme": "vscode-icons",
    "editor.fontSize": 20,
    "editor.fontFamily": "JetBrains Mono",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": true,
    },
    "editor.formatOnSave": true,
    "editor.mouseWheelZoom": true,
    "window.zoomLevel": 0.8,
    "editor.stickyScroll.enabled": false,
    "explorer.confirmDelete": false,
    "liveServer.settings.donotShowInfoMsg": true,
    "window.menuBarVisibility": "toggle",
    "workbench.layoutControl.enabled": false,
    "workbench.statusBar.visible": false, // Oculta a barra inferior
    "window.commandCenter": false,
    "workbench.activityBar.visible": false, // Oculta a barra lateral
    "editor.minimap.enabled": false, // Remove o minimapa
    "editor.lineNumbers": "off", // Oculta números das linhas
    "editor.renderLineHighlight": "none", // Sem destaque da linha atual
    "editor.renderWhitespace": "none", // Sem espaços visíveis
    "editor.wordWrap": "on", // Quebra automática de linha
    "editor.cursorSmoothCaretAnimation": true,
    "editor.smoothScrolling": true,
    "editor.scrollBeyondLastLine": false,
    "explorer.compactFolders": false,
    "terminal.integrated.fontSize": 13,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "telemetry.telemetryLevel": "off",
    "symbols.hidesExplorerArrows": false
}
